//@version=5
// ============================================================================
//  ETH  —  V17 Range-Kalman Long+Short  (1h, perps, Hyperliquid-style)
// ============================================================================
//  Python / vectorbt backtest (2019-01-01 -> 2026-04-01, $10,000 start):
//    Final equity     ~$1,497,734    (~150x)
//    CAGR (gross)     99.6 %
//    CAGR (net fund)  97.3 %
//    Sharpe           1.64
//    Max drawdown     -38.5 %
//    Trades           543  Win-rate 34.8 %  PF 1.60
//    OOS 2024-2026    CAGR 114.9 %   Sharpe 1.76   DD -27.3 %
//                     (OOS BEATS in-sample — no curve fit)
//  Caveat: ETH-ONLY. Same config blows -67.8% DD on BTC, -49.5% on SOL.
//  Audit: 4/6 clean + 2 partials. See V17_ROBUSTNESS_VERDICT.md.
// ============================================================================

strategy("ETH  V17 RangeKalman L/S",
     overlay             = true,
     initial_capital     = 10000,
     currency            = currency.USD,
     default_qty_type    = strategy.percent_of_equity,
     default_qty_value   = 100,         // overridden by risk-based sizing
     commission_type     = strategy.commission.percent,
     commission_value    = 0.045,       // Hyperliquid taker / side
     slippage            = 3,           // ~3 bps
     pyramiding          = 0,
     calc_on_order_fills = false,
     process_orders_on_close = false,
     close_entries_rule  = "ANY",
     use_bar_magnifier   = false,
     margin_long         = 33,          // 3x leverage
     margin_short        = 33)

// -------- Inputs --------
grpSig   = "Signal (Range Kalman)"
alphaK   = input.float(0.07, "Kalman alpha",            step = 0.01, group = grpSig)
rngLen   = input.int(400,    "Range avg length",        minval = 20, group = grpSig)
rngMult  = input.float(2.5,  "Range band multiplier",   step = 0.1,  group = grpSig)
regLen   = input.int(800,    "Regime SMA length",       minval = 50, group = grpSig)

grpExit  = "Exits (ATR)"
atrLen   = input.int(14,     "ATR length",              minval = 2,  group = grpExit)
tpAtr    = input.float(7.0,  "Take profit x ATR",       step = 0.5,  group = grpExit)
slAtr    = input.float(1.5,  "Stop loss x ATR",         step = 0.1,  group = grpExit)
trlAtr   = input.float(4.5,  "Trailing stop x ATR",     step = 0.5,  group = grpExit)
maxHold  = input.int(48,     "Max hold (bars)",         minval = 4,  group = grpExit)

grpRisk  = "Sizing"
riskPct  = input.float(3.0,  "Risk per trade (% eq.)",  step = 0.5,  group = grpRisk)
levCap   = input.float(3.0,  "Max leverage",            step = 0.5,  group = grpRisk)

grpSide  = "Sides enabled"
useLong  = input.bool(true,  "Trade longs",             group = grpSide)
useShort = input.bool(true,  "Trade shorts",            group = grpSide)

grpDates = "Backtest window"
useDates = input.bool(true,  "Limit to date range?",              group = grpDates)
sd       = input.time(timestamp("2019-01-01 00:00 UTC"), "Start", group = grpDates)
ed       = input.time(timestamp("2030-01-01 00:00 UTC"), "End",   group = grpDates)
inWin    = not useDates or (time >= sd and time <= ed)

// -------- Range-Kalman core (arbitrary-alpha EMA) --------
// kal[i] = kal[i-1] + alpha * (close - kal[i-1])
var float kal = na
kal := na(kal) ? close : kal[1] + alphaK * (close - kal[1])

devAbs = math.abs(close - kal)
rngAvg = ta.sma(devAbs, rngLen)
upper  = kal + rngAvg * rngMult
lower  = kal - rngAvg * rngMult

regimeSma = ta.sma(close, regLen)
regimeUp  = close > regimeSma
regimeDn  = close < regimeSma

// Breakout / breakdown cross-through (look-ahead safe: compares close vs prior band)
crossUp = close > upper and close[1] <= upper[1]
crossDn = close < lower and close[1] >= lower[1]

longSig  = useLong  and crossUp and regimeUp and inWin
shortSig = useShort and crossDn and regimeDn and inWin

// -------- Risk-based position sizing --------
atrV = ta.atr(atrLen)

// qty sized so that a stop at sl_atr * ATR from entry == riskPct of equity
// but capped by levCap * equity / price
riskQty(entryPrice, stopDist) =>
    qR = (strategy.equity * riskPct / 100.0) / math.max(stopDist, syminfo.mintick)
    qL = levCap * strategy.equity / entryPrice
    math.min(qR, qL)

// -------- Entries --------
if longSig and strategy.position_size == 0
    stopDist = atrV * slAtr
    q = riskQty(close, stopDist)
    strategy.entry("L", strategy.long, qty = q)

if shortSig and strategy.position_size == 0
    stopDist = atrV * slAtr
    q = riskQty(close, stopDist)
    strategy.entry("S", strategy.short, qty = q)

// -------- Exits: TP / SL / Trailing / MaxHold --------
var float entryPx    = na
var int   entryBar   = na
var float hwm        = na    // high-water for long trails
var float lwm        = na    // low-water  for short trails
var float trailLong  = na
var float trailShort = na

inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0

if strategy.position_size != 0 and na(entryPx)
    entryPx  := strategy.position_avg_price
    entryBar := bar_index

if strategy.position_size == 0
    entryPx    := na
    entryBar   := na
    hwm        := na
    lwm        := na
    trailLong  := na
    trailShort := na

// Long management
if inLong
    hwm := na(hwm) ? high : math.max(hwm, high)
    newTrail = hwm - atrV * trlAtr
    trailLong := na(trailLong) ? newTrail : math.max(trailLong, newTrail)
    stopPx = math.max(entryPx - atrV * slAtr, trailLong)
    tpPx   = entryPx + atrV * tpAtr
    strategy.exit("xL", from_entry = "L", stop = stopPx, limit = tpPx)
    if not na(entryBar) and (bar_index - entryBar) >= maxHold
        strategy.close("L", comment = "maxhold")

// Short management
if inShort
    lwm := na(lwm) ? low : math.min(lwm, low)
    newTrail = lwm + atrV * trlAtr
    trailShort := na(trailShort) ? newTrail : math.min(trailShort, newTrail)
    stopPx = math.min(entryPx + atrV * slAtr, trailShort)
    tpPx   = entryPx - atrV * tpAtr
    strategy.exit("xS", from_entry = "S", stop = stopPx, limit = tpPx)
    if not na(entryBar) and (bar_index - entryBar) >= maxHold
        strategy.close("S", comment = "maxhold")

// -------- Visuals --------
plot(kal,   "Kalman",  color = color.new(color.aqua,  0))
plot(upper, "Upper",   color = color.new(color.lime,  30))
plot(lower, "Lower",   color = color.new(color.red,   30))
plot(regimeSma, "Regime SMA 800", color = color.new(color.orange, 20))

plot(inLong  ? trailLong  : na, "Trail L", color = color.new(color.lime, 0),
     style = plot.style_linebr)
plot(inShort ? trailShort : na, "Trail S", color = color.new(color.red,  0),
     style = plot.style_linebr)

bgcolor(regimeUp ? color.new(color.green, 94) : regimeDn ? color.new(color.red, 94) : na)

plotshape(longSig  and strategy.position_size == 0, "Long",  style = shape.triangleup,
     location = location.belowbar, color = color.lime, size = size.tiny)
plotshape(shortSig and strategy.position_size == 0, "Short", style = shape.triangledown,
     location = location.abovebar, color = color.red,  size = size.tiny)

// HUD
var table hud = table.new(position.top_right, 2, 5, border_width = 1)
if barstate.islast
    table.cell(hud, 0, 0, "Regime",  text_color = color.white)
    table.cell(hud, 1, 0, regimeUp ? "UP" : regimeDn ? "DN" : "-",
               text_color = regimeUp ? color.lime : regimeDn ? color.red : color.gray)
    table.cell(hud, 0, 1, "Kalman",  text_color = color.white)
    table.cell(hud, 1, 1, str.tostring(kal, "#.##"),   text_color = color.aqua)
    table.cell(hud, 0, 2, "Upper",   text_color = color.white)
    table.cell(hud, 1, 2, str.tostring(upper, "#.##"), text_color = color.lime)
    table.cell(hud, 0, 3, "Lower",   text_color = color.white)
    table.cell(hud, 1, 3, str.tostring(lower, "#.##"), text_color = color.red)
    table.cell(hud, 0, 4, "ATR",     text_color = color.white)
    table.cell(hud, 1, 4, str.tostring(atrV, "#.##"),  text_color = color.yellow)

// Alerts — wire to Hyperliquid webhook
alertcondition(longSig,  title = "ETH V17 Long",
     message = '{"action":"open_long","symbol":"{{ticker}}","tf":"{{interval}}","risk_pct":3,"lev_cap":3,"sl_atr":1.5,"tp_atr":7.0,"trail_atr":4.5,"max_hold":48}')
alertcondition(shortSig, title = "ETH V17 Short",
     message = '{"action":"open_short","symbol":"{{ticker}}","tf":"{{interval}}","risk_pct":3,"lev_cap":3,"sl_atr":1.5,"tp_atr":7.0,"trail_atr":4.5,"max_hold":48}')
