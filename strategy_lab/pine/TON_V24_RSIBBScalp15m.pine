//@version=5
// ============================================================================
//  TON  —  V24 RSI + BB Mean-Revert Scalp  (15m, perps, Hyperliquid-style)
// ============================================================================
//  Same family as LINK / DOGE V24. TON only listed 2024-08 so we have no IS
//  slice — OOS-only sample.
//
//  Python backtest (post-listing -> 2026-04, $10k start, 9 bps fee + 3 bps slip):
//    FULL  n=49   CAGR (net) +21.7%   Sharpe +1.02   DD -19.9%   PF 1.65
//    IS:   none (listed 2024-08).
//    OOS:  equal to full — 2024-08 → 2026-04.
//
//  Status: PAPER-TEST ONLY. Positive Sharpe but no out-of-sample verification
//          possible because of short history. V23 TON Keltner+ADX (+169% CAGR
//          Sharpe 2.06 at 2h) remains the main TON allocation; this is a
//          candidate diversifier — not a replacement.
// ============================================================================

strategy("TON  V24 RSI+BB Scalp 15m",
     overlay             = true,
     initial_capital     = 10000,
     currency            = currency.USD,
     default_qty_type    = strategy.percent_of_equity,
     default_qty_value   = 100,
     commission_type     = strategy.commission.percent,
     commission_value    = 0.045,
     slippage            = 3,
     pyramiding          = 0,
     process_orders_on_close = false,
     close_entries_rule  = "ANY",
     margin_long         = 33,
     margin_short        = 33)

grpSig = "Signal (RSI + BB mean-revert)"
rsiN   = input.int(14,   "RSI length",               minval = 2,  group = grpSig)
rsiLo  = input.float(25, "RSI long threshold (<)",   step = 1,    group = grpSig)
rsiHi  = input.float(75, "RSI short threshold (>)",  step = 1,    group = grpSig)
bbN    = input.int(40,   "BB length (bars @ 15m)",   minval = 10, group = grpSig)
bbK    = input.float(2.0,"BB std-dev multiplier",    step = 0.1,  group = grpSig)
regLen = input.int(400,  "Regime SMA length (bars @ 15m)", minval = 50, group = grpSig)

grpExit = "Exits (ATR)"
atrLen  = input.int(14,   "ATR length", minval = 2, group = grpExit)
tpAtr   = input.float(4.0, "TP x ATR",   step = 0.5, group = grpExit)
slAtr   = input.float(1.5, "SL x ATR",   step = 0.1, group = grpExit)
trlAtr  = input.float(2.5, "Trail x ATR", step = 0.5, group = grpExit)
maxHold = input.int(32,   "Max hold (bars @ 15m)", minval = 4, group = grpExit)

grpRisk = "Sizing"
riskPct = input.float(5.0, "Risk per trade (% eq.)", step = 0.5, group = grpRisk)
levCap  = input.float(3.0, "Max leverage",           step = 0.5, group = grpRisk)

grpSide  = "Sides"
useLong  = input.bool(true, "Longs",  group = grpSide)
useShort = input.bool(true, "Shorts", group = grpSide)

rsiVal = ta.rsi(close, rsiN)
basis  = ta.sma(close, bbN)
dev    = ta.stdev(close, bbN)
upper  = basis + bbK * dev
lower  = basis - bbK * dev
regSma = ta.sma(close, regLen)

regimeUp = close > regSma
regimeDn = close < regSma

longSig  = useLong  and (rsiVal < rsiLo) and (close < lower) and regimeUp
shortSig = useShort and (rsiVal > rsiHi) and (close > upper) and regimeDn

atrVal      = ta.atr(atrLen)
stopDist    = slAtr * atrVal
riskDollars = strategy.equity * (riskPct / 100.0)
qtySized    = stopDist > 0 ? math.min(riskDollars / stopDist, strategy.equity * levCap / close) : 0

if longSig and strategy.position_size == 0
    strategy.entry("L", strategy.long, qty = qtySized,
                   alert_message = '{"action":"buy","ticker":"{{ticker}}","qty":"{{strategy.order.contracts}}","price":"{{close}}"}')

if shortSig and strategy.position_size == 0
    strategy.entry("S", strategy.short, qty = qtySized,
                   alert_message = '{"action":"sell","ticker":"{{ticker}}","qty":"{{strategy.order.contracts}}","price":"{{close}}"}')

var float trailStop = na
var int   barsIn    = 0

if strategy.position_size > 0
    barsIn := barsIn + 1
    tp    = strategy.position_avg_price + tpAtr * atrVal
    hsl   = strategy.position_avg_price - slAtr * atrVal
    trail = high - trlAtr * atrVal
    trailStop := na(trailStop) ? hsl : math.max(trailStop, trail)
    trailStop := math.max(trailStop, hsl)
    strategy.exit("X-L", "L", limit = tp, stop = trailStop)
    if barsIn >= maxHold
        strategy.close("L", comment = "maxHold")
else if strategy.position_size < 0
    barsIn := barsIn + 1
    tp    = strategy.position_avg_price - tpAtr * atrVal
    hsl   = strategy.position_avg_price + slAtr * atrVal
    trail = low + trlAtr * atrVal
    trailStop := na(trailStop) ? hsl : math.min(trailStop, trail)
    trailStop := math.min(trailStop, hsl)
    strategy.exit("X-S", "S", limit = tp, stop = trailStop)
    if barsIn >= maxHold
        strategy.close("S", comment = "maxHold")
else
    trailStop := na
    barsIn := 0

plot(basis,  "BB mid",     color = color.new(color.yellow, 0))
plot(upper,  "BB upper",   color = color.new(color.red,    40))
plot(lower,  "BB lower",   color = color.new(color.lime,   40))
plot(regSma, "Regime SMA", color = color.new(color.aqua,   50))
plotshape(longSig,  title = "Long",  style = shape.triangleup,   location = location.belowbar, color = color.lime, size = size.tiny)
plotshape(shortSig, title = "Short", style = shape.triangledown, location = location.abovebar, color = color.red,  size = size.tiny)
