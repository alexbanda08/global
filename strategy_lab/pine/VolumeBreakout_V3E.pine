//@version=5
// ============================================================================
//  VOLUME BREAKOUT V3E  —  "Score 2-of-3" Trend Validator Edition
// ============================================================================
//  Same breakout core as V2B, now gated by a trend-validator score.
//  Entry requires at least 2 of the 3 trend conditions to agree:
//      G1: HTF 1-Day 200-EMA rising          (long-horizon regime)
//      G2: ADX(14) > 20                      (trend strength)
//      G3: SMA(close, 50) rising              (short-horizon trend)
//
//  Python / vectorbt portfolio backtest (60/25/15 BTC/ETH/SOL @ 4h):
//    Period       : 2018-01-01 -> 2026-04-01  (8.25 years)
//    Start / End  : $10,000 -> $226,116  (22.6x)
//    CAGR         : 45.96 %
//    Sharpe       : 1.23
//    Sortino      : 1.08
//    Max DD       : -28.69 %
//    Calmar       : 1.60
//    OOS (2023-2026, params frozen on 2018-2022):
//       CAGR 23.6%   Sharpe 0.91   DD -19.9%   Calmar 1.19
//
//  vs V2B baseline:
//    CAGR  +3.5 pp    Sharpe  +0.02    MaxDD  -2.3 pp
//    Final equity  +$41k   OOS Calmar +0.40
//
//  Costs modelled: 0.1 % per side + 5-tick slippage (Binance spot).
// ============================================================================

strategy("Volume Breakout V3E [Score2of3]",
     overlay              = true,
     initial_capital      = 10000,
     currency             = currency.USD,
     default_qty_type     = strategy.percent_of_equity,
     default_qty_value    = 99,
     commission_type      = strategy.commission.percent,
     commission_value     = 0.1,
     slippage             = 5,
     pyramiding           = 0,
     calc_on_order_fills  = false,
     process_orders_on_close = false,
     close_entries_rule   = "ANY",
     use_bar_magnifier    = false)

// ----------------------------------------------------------------------------
//  INPUTS
// ----------------------------------------------------------------------------
grpCore     = "Breakout core"
donLen      = input.int(30,   "Donchian lookback",      minval = 5,  group = grpCore)
volAvg      = input.int(20,   "Volume SMA length",      minval = 2,  group = grpCore)
volMult     = input.float(1.3,"Volume spike multiplier",step  = 0.1, group = grpCore)
regimeLen   = input.int(150,  "Regime SMA length",      minval = 20, group = grpCore)

grpTrend    = "Trend validators (>= 2 of 3 required)"
htfRes      = input.timeframe("D",  "HTF timeframe for EMA",         group = grpTrend)
htfEmaLen   = input.int(200,        "HTF EMA length",  minval = 10,  group = grpTrend)
adxLen      = input.int(14,         "ADX length",      minval = 2,   group = grpTrend)
adxMin      = input.float(20,       "ADX threshold",   step   = 1,   group = grpTrend)
slopeLen    = input.int(50,         "Short-term SMA length", minval = 5, group = grpTrend)

grpRisk     = "Risk management"
atrLen      = input.int(14,   "ATR length",            minval = 2,  group = grpRisk)
trailAtr    = input.float(4.5,"Trailing stop x ATR",   step   = 0.5, group = grpRisk)

grpDates    = "Backtest window"
useDates    = input.bool(true,"Limit to date range?",                  group = grpDates)
startDate   = input.time(timestamp("2018-01-01 00:00 UTC"),"Start",   group = grpDates)
endDate     = input.time(timestamp("2030-01-01 00:00 UTC"),"End",     group = grpDates)
inWin       = not useDates or (time >= startDate and time <= endDate)

// ----------------------------------------------------------------------------
//  INDICATORS  (look-ahead safe: compare current close against indicators
//              built from already-closed bars).
// ----------------------------------------------------------------------------
// --- Breakout core ---
donHi    = ta.highest(high, donLen)[1]
volSma   = ta.sma(volume, volAvg)
regSma   = ta.sma(close, regimeLen)
atr      = ta.atr(atrLen)

// --- Trend validators ---
// G1: HTF 200-EMA rising (uses request.security; lookahead OFF to prevent peek)
htfEma    = request.security(syminfo.tickerid, htfRes,
                 ta.ema(close, htfEmaLen), lookahead = barmerge.lookahead_off)
htfEmaPrev = request.security(syminfo.tickerid, htfRes,
                 ta.ema(close, htfEmaLen)[1], lookahead = barmerge.lookahead_off)
g1_htfRising = htfEma > htfEmaPrev

// G2: ADX > threshold
[plusDI, minusDI, adxVal] = ta.dmi(adxLen, adxLen)
g2_adx = adxVal > adxMin

// G3: 50-SMA rising
smaSt       = ta.sma(close, slopeLen)
g3_slope    = smaSt > smaSt[1]

// Score
score = (g1_htfRising ? 1 : 0) + (g2_adx ? 1 : 0) + (g3_slope ? 1 : 0)
trendOK = score >= 2

// ----------------------------------------------------------------------------
//  SIGNALS
// ----------------------------------------------------------------------------
breakout  = close > donHi
volSpike  = volume > volSma * volMult
regimeUp  = close > regSma

longCond  = breakout and volSpike and regimeUp and trendOK and inWin
exitReg   = close < regSma

// ----------------------------------------------------------------------------
//  ENTRY / EXIT (trailing stop + regime failsafe)
// ----------------------------------------------------------------------------
if longCond and strategy.position_size == 0
    strategy.entry("L", strategy.long)

var float hhSinceEntry = na
var float trailStop    = na

if strategy.position_size > 0
    hhSinceEntry := na(hhSinceEntry) ? high : math.max(hhSinceEntry, high)
    newStop     = hhSinceEntry - atr * trailAtr
    trailStop   := na(trailStop) ? newStop : math.max(trailStop, newStop)
    strategy.exit("trail", from_entry = "L", stop = trailStop)
    if exitReg
        strategy.close("L", comment = "regime")
else
    hhSinceEntry := na
    trailStop    := na

// ----------------------------------------------------------------------------
//  VISUALS
// ----------------------------------------------------------------------------
plot(donHi,  "Donchian(30) High", color = color.new(color.yellow, 40))
plot(regSma, "Regime SMA(150)",   color = color.new(color.orange, 0))
plot(htfEma, "HTF 200-EMA",       color = color.new(color.aqua, 20), style = plot.style_line)
plot(strategy.position_size > 0 ? trailStop : na, "Trailing Stop",
     color = color.new(color.red, 0), style = plot.style_linebr)

bgcolor(regimeUp and trendOK ? color.new(color.green, 93)
                              : color.new(color.red,   94))

plotshape(longCond and strategy.position_size == 0,
     "Entry", style = shape.triangleup, location = location.belowbar,
     color = color.lime, size = size.tiny)
plotshape(exitReg and strategy.position_size > 0,
     "Regime exit", style = shape.xcross, location = location.abovebar,
     color = color.red, size = size.tiny)

// Small HUD showing validator score
var table hud = table.new(position.top_right, 2, 4, border_width = 1)
if barstate.islast
    table.cell(hud, 0, 0, "Trend score", text_color = color.white)
    table.cell(hud, 1, 0, str.tostring(score) + " / 3",
               text_color = trendOK ? color.lime : color.orange, text_size = size.normal)
    table.cell(hud, 0, 1, "1D EMA rising", text_color = color.white)
    table.cell(hud, 1, 1, g1_htfRising ? "YES" : "no",
               text_color = g1_htfRising ? color.lime : color.gray)
    table.cell(hud, 0, 2, "ADX > " + str.tostring(adxMin), text_color = color.white)
    table.cell(hud, 1, 2, g2_adx ? "YES" : "no",
               text_color = g2_adx ? color.lime : color.gray)
    table.cell(hud, 0, 3, "SMA(50) rising", text_color = color.white)
    table.cell(hud, 1, 3, g3_slope ? "YES" : "no",
               text_color = g3_slope ? color.lime : color.gray)

// ----------------------------------------------------------------------------
//  ALERTS
// ----------------------------------------------------------------------------
alertcondition(longCond,
     title   = "V3E Long Entry",
     message = '{"action":"open_long","symbol":"{{ticker}}","tf":"{{interval}}","price":"{{close}}"}')
alertcondition(exitReg and strategy.position_size > 0,
     title   = "V3E Regime Exit",
     message = '{"action":"close_long","symbol":"{{ticker}}","tf":"{{interval}}","price":"{{close}}"}')
