//@version=5
// SOL V30 ConnorsRSI 4h
// Connors_RSI — V30 winner, OOS PASS
// Params: {"crsi_lo": 15, "crsi_hi": 85, "adx_max": 28}  | Exits: TP=10×ATR  SL=2.0×ATR  Trail=5.0×ATR  MH=40  Risk=3.0%  Lev=3.0×
// Sim: 0.045% taker fee, 3 bps slippage, ATR-risk sizing, next-bar-open fills.
strategy("SOL V30 ConnorsRSI 4h", overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.cash, default_qty_value=0,
     commission_type=strategy.commission.percent, commission_value=0.045,
     slippage=3, pyramiding=0, calc_on_every_tick=false,
     process_orders_on_close=false)

// ---- Inputs ----
crsi_lo = input.float(15, "CRSI lower threshold")
crsi_hi = input.float(85, "CRSI upper threshold")
adx_max = input.int(28, "ADX max for range gate")

// ---- Shared ----
risk_per_trade = 3.0 / 100.0
lev_cap        = 3.0
tp_atr         = 10
sl_atr         = 2.0
trail_atr      = 5.0
max_hold       = 40

// ---- Indicators ----
atr_v = ta.atr(14)

// CRSI = (RSI(3) + RSI(streak,2) + PercentRank(ROC_1, 100)) / 3
rsi3 = ta.rsi(close, 3)

// streak
var float streak = 0.0
dir_ = math.sign(close - close[1])
streak := dir_ == 0 ? 0.0 :
         (math.sign(streak[1]) == dir_ or streak[1] == 0) ? streak[1] + dir_ : dir_
rsi_streak = ta.rsi(streak, 2)

roc1 = (close - close[1]) / close[1] * 100
pct_rank = ta.percentrank(roc1, 100)
crsi = (rsi3 + rsi_streak + pct_rank) / 3

[_dp, _dm, adx_v2] = ta.dmi(14, 14)
range_ok = adx_v2 < adx_max

long_edge  = crsi > crsi_lo and crsi[1] <= crsi_lo
short_edge = crsi < crsi_hi and crsi[1] >= crsi_hi
long_sig   = range_ok and long_edge
short_sig  = range_ok and short_edge

// ---- Sizing ----
qty_from_risk() =>
    risk_dollars = strategy.equity * risk_per_trade
    sl_dist = sl_atr * atr_v
    qty_risk = sl_dist > 0 ? risk_dollars / sl_dist : 0
    qty_cap  = (strategy.equity * lev_cap) / close
    math.min(qty_risk, qty_cap)

// ---- Entries ----
if long_sig
    q = qty_from_risk()
    if q > 0
        strategy.entry("L", strategy.long, qty=q)
        strategy.exit("Lx", "L", profit=tp_atr*atr_v/syminfo.mintick, loss=sl_atr*atr_v/syminfo.mintick,
                      trail_points=trail_atr*atr_v/syminfo.mintick, trail_offset=trail_atr*atr_v/syminfo.mintick)

if short_sig
    q = qty_from_risk()
    if q > 0
        strategy.entry("S", strategy.short, qty=q)
        strategy.exit("Sx", "S", profit=tp_atr*atr_v/syminfo.mintick, loss=sl_atr*atr_v/syminfo.mintick,
                      trail_points=trail_atr*atr_v/syminfo.mintick, trail_offset=trail_atr*atr_v/syminfo.mintick)

// ---- Max hold timeout ----
var int bars_in = 0
bars_in := strategy.position_size != 0 ? bars_in + 1 : 0
if bars_in >= max_hold
    strategy.close_all()
