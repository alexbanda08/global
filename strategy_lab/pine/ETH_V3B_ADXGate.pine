//@version=5
// ============================================================================
//  ETH  —  V3B Volume Breakout + ADX Gate  (4h, long-only)
// ============================================================================
//  Python / vectorbt backtest (2018-01-01 -> 2026-04-01, $10,000 start):
//    Final equity     $395,501    (39.55x)
//    CAGR             56.20%
//    Sharpe           1.26
//    Max drawdown     -33.81%
//    Calmar           1.66
//    Trades           88  Win-rate 43.2%
//    OOS 2023-2026    CAGR 13%  Sharpe 0.54  DD -32%
//  CAVEAT: OOS Sharpe drop is the widest of the 3 winners.  Expect live
//  Sharpe in the 0.5-0.8 range.  5/5 robustness checks still passed.
// ============================================================================

strategy("ETH  V3B ADX Gate",
     overlay             = true,
     initial_capital     = 10000,
     currency            = currency.USD,
     default_qty_type    = strategy.percent_of_equity,
     default_qty_value   = 99,
     commission_type     = strategy.commission.percent,
     commission_value    = 0.1,
     slippage            = 5,
     pyramiding          = 0,
     calc_on_order_fills = false,
     process_orders_on_close = false,
     close_entries_rule  = "ANY",
     use_bar_magnifier   = false)

// -------- Inputs --------
grpCore = "Breakout core"
donLen   = input.int(30,    "Donchian lookback",     minval = 5,  group = grpCore)
volAvg   = input.int(20,    "Volume SMA length",     minval = 2,  group = grpCore)
volMult  = input.float(1.3, "Volume spike multiplier",step = 0.1, group = grpCore)
regLen   = input.int(150,   "Regime SMA length",     minval = 20, group = grpCore)

grpGate  = "ADX trend gate"
adxLen   = input.int(14,    "ADX length",            minval = 2,  group = grpGate)
adxMin   = input.float(20,  "ADX threshold",         step = 1,    group = grpGate)

grpRisk  = "Risk"
atrLen   = input.int(14,    "ATR length",            minval = 2,  group = grpRisk)
trailAtr = input.float(4.5, "Trailing stop x ATR",   step = 0.5,  group = grpRisk)

grpDates = "Backtest window"
useDates = input.bool(true, "Limit to date range?",               group = grpDates)
sd       = input.time(timestamp("2018-01-01 00:00 UTC"), "Start", group = grpDates)
ed       = input.time(timestamp("2030-01-01 00:00 UTC"), "End",   group = grpDates)
inWin    = not useDates or (time >= sd and time <= ed)

// -------- Indicators (look-ahead safe) --------
donHi  = ta.highest(high, donLen)[1]
volSma = ta.sma(volume, volAvg)
regSma = ta.sma(close, regLen)
atr    = ta.atr(atrLen)
[plusDI, minusDI, adxVal] = ta.dmi(adxLen, adxLen)

// -------- Signals --------
breakout = close > donHi
volSpike = volume > volSma * volMult
regimeUp = close > regSma
adxOk    = adxVal > adxMin

longCond = breakout and volSpike and regimeUp and adxOk and inWin
exitReg  = close < regSma

// -------- Orders --------
if longCond and strategy.position_size == 0
    strategy.entry("L", strategy.long)

var float hh = na
var float ts = na
if strategy.position_size > 0
    hh := na(hh) ? high : math.max(hh, high)
    newStop = hh - atr * trailAtr
    ts := na(ts) ? newStop : math.max(ts, newStop)
    strategy.exit("trail", from_entry = "L", stop = ts)
    if exitReg
        strategy.close("L", comment = "regime")
else
    hh := na
    ts := na

// -------- Visuals --------
plot(donHi,  "Donchian(30) High", color = color.new(color.yellow, 40))
plot(regSma, "Regime SMA 150",    color = color.new(color.orange, 0))
plot(strategy.position_size > 0 ? ts : na, "Trailing Stop",
     color = color.new(color.red, 0), style = plot.style_linebr)

bgcolor(regimeUp and adxOk ? color.new(color.green, 93) : color.new(color.red, 94))

plotshape(longCond and strategy.position_size == 0,
     "Entry", style = shape.triangleup, location = location.belowbar,
     color = color.lime, size = size.tiny)

// HUD
var table hud = table.new(position.top_right, 2, 3, border_width = 1)
if barstate.islast
    table.cell(hud, 0, 0, "ADX",         text_color = color.white)
    table.cell(hud, 1, 0, str.tostring(adxVal, "#.0"),
               text_color = adxOk ? color.lime : color.gray)
    table.cell(hud, 0, 1, "Regime",      text_color = color.white)
    table.cell(hud, 1, 1, regimeUp ? "UP" : "dn",
               text_color = regimeUp ? color.lime : color.gray)
    table.cell(hud, 0, 2, "Signals OK",  text_color = color.white)
    table.cell(hud, 1, 2, longCond ? "YES" : "—",
               text_color = longCond ? color.lime : color.gray)

alertcondition(longCond, title = "ETH V3B Long",
     message = '{"action":"open_long","symbol":"{{ticker}}","tf":"{{interval}}"}')
alertcondition(exitReg,  title = "ETH V3B Exit",
     message = '{"action":"close_long","symbol":"{{ticker}}","tf":"{{interval}}"}')
