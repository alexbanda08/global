//@version=5
// ============================================================================
//  SUI  —  V25 MTF Confluence (30m)   —  DIVERSIFIER OVERLAY
// ============================================================================
//  Same family as AVAX/SOL V25 — EMA cross gated by a 4h trend filter, but
//  this one runs on 30m bars (so lengths 40/100 = ~20h/50h of memory).
//
//  Python backtest (2020-01 -> 2026-04, $10,000 start, 9 bps fee + 3 bps slip):
//    FULL  n=311   CAGR (net) +37.7%   Sharpe +0.94   DD -38.9%   PF 1.25
//      IS  (2020-2023)   n=76    CAGR +50.2%   Sharpe +1.10
//      OOS (2024-2026)   n=234   CAGR +30.9%   Sharpe +0.84   <- OOS holds
//
//  Status: DIVERSIFIER OVERLAY. V23 SUI BB-Break 4h (+160% CAGR Sh 1.66)
//    dominates on raw CAGR, but the 30m MTF trades a completely different
//    time-frame — combined correlation should be low. Suggested 25% overlay.
// ============================================================================

strategy("SUI  V25 MTF Conf 30m",
     overlay             = true,
     initial_capital     = 10000,
     currency            = currency.USD,
     default_qty_type    = strategy.percent_of_equity,
     default_qty_value   = 100,
     commission_type     = strategy.commission.percent,
     commission_value    = 0.045,
     slippage            = 3,
     pyramiding          = 0,
     process_orders_on_close = false,
     close_entries_rule  = "ANY",
     margin_long         = 33,
     margin_short        = 33)

grpSig  = "Signal (MTF EMA crossover)"
fastLen = input.int(40,  "Fast EMA length (bars @ 30m)", minval = 2, group = grpSig)
slowLen = input.int(100, "Slow EMA length (bars @ 30m)", minval = 5, group = grpSig)
h4Len   = input.int(50,  "4h EMA trend filter length",   minval = 5, group = grpSig)

grpExit = "Exits (ATR)"
atrLen  = input.int(14,   "ATR length", minval = 2, group = grpExit)
tpAtr   = input.float(7.0, "TP x ATR",  step = 0.5, group = grpExit)
slAtr   = input.float(2.0, "SL x ATR",  step = 0.1, group = grpExit)
trlAtr  = input.float(4.0, "Trail x ATR", step = 0.5, group = grpExit)
maxHold = input.int(80,   "Max hold (bars @ 30m)", minval = 4, group = grpExit)

grpRisk = "Sizing"
riskPct = input.float(3.0, "Risk per trade (% eq.)", step = 0.5, group = grpRisk)
levCap  = input.float(3.0, "Max leverage",           step = 0.5, group = grpRisk)

grpSide  = "Sides"
useLong  = input.bool(true, "Longs",  group = grpSide)
useShort = input.bool(true, "Shorts", group = grpSide)

emaFast = ta.ema(close, fastLen)
emaSlow = ta.ema(close, slowLen)
crossUp = ta.crossover(emaFast,  emaSlow)
crossDn = ta.crossunder(emaFast, emaSlow)

h4Close  = request.security(syminfo.tickerid, "240", close)
h4Ema    = request.security(syminfo.tickerid, "240", ta.ema(close, h4Len))
h4TrendUp = h4Close > h4Ema
h4TrendDn = h4Close < h4Ema

longSig  = useLong  and crossUp and h4TrendUp
shortSig = useShort and crossDn and h4TrendDn

atrVal      = ta.atr(atrLen)
stopDist    = slAtr * atrVal
riskDollars = strategy.equity * (riskPct / 100.0)
qtySized    = stopDist > 0 ? math.min(riskDollars / stopDist, strategy.equity * levCap / close) : 0

if longSig and strategy.position_size == 0
    strategy.entry("L", strategy.long, qty = qtySized,
                   alert_message = '{"action":"buy","ticker":"{{ticker}}","qty":"{{strategy.order.contracts}}","price":"{{close}}"}')

if shortSig and strategy.position_size == 0
    strategy.entry("S", strategy.short, qty = qtySized,
                   alert_message = '{"action":"sell","ticker":"{{ticker}}","qty":"{{strategy.order.contracts}}","price":"{{close}}"}')

var float trailStop = na
var int   barsIn    = 0

if strategy.position_size > 0
    barsIn := barsIn + 1
    tp    = strategy.position_avg_price + tpAtr * atrVal
    hsl   = strategy.position_avg_price - slAtr * atrVal
    trail = high - trlAtr * atrVal
    trailStop := na(trailStop) ? hsl : math.max(trailStop, trail)
    trailStop := math.max(trailStop, hsl)
    strategy.exit("X-L", "L", limit = tp, stop = trailStop)
    if barsIn >= maxHold
        strategy.close("L", comment = "maxHold")
else if strategy.position_size < 0
    barsIn := barsIn + 1
    tp    = strategy.position_avg_price - tpAtr * atrVal
    hsl   = strategy.position_avg_price + slAtr * atrVal
    trail = low + trlAtr * atrVal
    trailStop := na(trailStop) ? hsl : math.min(trailStop, trail)
    trailStop := math.min(trailStop, hsl)
    strategy.exit("X-S", "S", limit = tp, stop = trailStop)
    if barsIn >= maxHold
        strategy.close("S", comment = "maxHold")
else
    trailStop := na
    barsIn := 0

plot(emaFast, "EMA fast", color = color.new(color.yellow, 0))
plot(emaSlow, "EMA slow", color = color.new(color.aqua,   0))
plot(h4Ema,   "4h EMA",   color = color.new(color.fuchsia, 30))
bgcolor(h4TrendUp ? color.new(color.green, 92) : h4TrendDn ? color.new(color.red, 92) : na)
plotshape(longSig,  title = "Long",  style = shape.triangleup,   location = location.belowbar, color = color.lime, size = size.tiny)
plotshape(shortSig, title = "Short", style = shape.triangledown, location = location.abovebar, color = color.red,  size = size.tiny)
