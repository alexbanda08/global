//@version=5
// ============================================================================
//  VOLUME BREAKOUT V2B  —  Cross-Asset Crypto Strategy (BTC/ETH/SOL @ 4h)
// ============================================================================
//  Python / vectorbt backtest (engine matches Pine execution: signal at bar i,
//  filled at open of bar i+1, 0.1% fees, 5-tick slippage):
//
//    Period: 2018-01-01  ->  2026-04-01  (8.25 years)
//    Portfolio 60/25/15 (BTC/ETH/SOL) on $10,000:
//       CAGR 47.81%  Sharpe 1.24  Sortino 1.08  MaxDD -31.0%  Calmar 1.54
//       Final equity: $250,760
//    Buy & Hold (same allocation):
//       CAGR 28.76%  Sharpe 0.71  MaxDD -90.87% Calmar 0.32   Final $80,423
//
//  Walk-forward: params picked on IS 2018-2022; OOS 2023-2026 remained
//  profitable (CAGR 20.2%, Sharpe 0.79, DD -24.1%).
//
//  Entry conditions (ALL must be true on the closed bar):
//    1) close > previous 30-bar Donchian high           (breakout)
//    2) volume > SMA(volume, 20) * 1.3                  (confirmation)
//    3) close > SMA(close, 150)                         (regime = up)
//
//  Exit conditions:
//    a) ATR(14) * 4.5 trailing stop (price-based trail)
//    b) close < SMA(close, 150)                         (regime flip — safety)
//
//  Designed for BTCUSDT, ETHUSDT, SOLUSDT on the 4h timeframe.
//  Apply to each symbol separately with its own capital share:
//      BTC 60% | ETH 25% | SOL 15%  of a $10k demo.
// ============================================================================

strategy("Volume Breakout V2B",
     overlay              = true,
     initial_capital      = 10000,
     currency             = currency.USD,
     default_qty_type     = strategy.percent_of_equity,
     default_qty_value    = 99,                             // single-asset sub-account
     commission_type      = strategy.commission.percent,
     commission_value     = 0.1,
     slippage             = 5,
     pyramiding           = 0,
     calc_on_order_fills  = false,                          // next-bar execution
     process_orders_on_close = false,
     close_entries_rule   = "ANY",
     use_bar_magnifier    = false)

// ----------------------------------------------------------------------------
// INPUTS
// ----------------------------------------------------------------------------
grpMain     = "Strategy"
donLen      = input.int(30,   "Donchian lookback",       minval = 5,  group = grpMain)
volAvg      = input.int(20,   "Volume SMA length",       minval = 2,  group = grpMain)
volMult     = input.float(1.3,"Volume spike × (vol/avg)",step   = 0.1, group = grpMain)
regimeLen   = input.int(150,  "Regime SMA length",       minval = 20, group = grpMain)

grpRisk     = "Risk management"
atrLen      = input.int(14,   "ATR length",              minval = 2,  group = grpRisk)
trailAtr    = input.float(4.5,"Trailing stop × ATR",     step   = 0.5, group = grpRisk)

grpDates    = "Backtest window"
useDates    = input.bool(true,"Limit to date range?",                  group = grpDates)
startDate   = input.time(timestamp("2018-01-01 00:00 UTC"),"Start",   group = grpDates)
endDate     = input.time(timestamp("2030-01-01 00:00 UTC"),"End",     group = grpDates)
inWin       = not useDates or (time >= startDate and time <= endDate)

// ----------------------------------------------------------------------------
// INDICATORS
//   We compare `close` against levels built from BARS ENDING BEFORE the
//   current close to prevent look-ahead. `ta.highest(high, N)[1]` = highest
//   of the PREVIOUS N completed bars (excludes current).
// ----------------------------------------------------------------------------
donHi   = ta.highest(high, donLen)[1]
volSma  = ta.sma(volume, volAvg)
regSma  = ta.sma(close, regimeLen)
atr     = ta.atr(atrLen)

// ----------------------------------------------------------------------------
// SIGNALS
// ----------------------------------------------------------------------------
breakout  = close > donHi
volSpike  = volume > volSma * volMult
regimeUp  = close > regSma

longCond  = breakout and volSpike and regimeUp and inWin
exitReg   = close < regSma

// ----------------------------------------------------------------------------
// ENTRY
// ----------------------------------------------------------------------------
if longCond and strategy.position_size == 0
    strategy.entry("L", strategy.long)

// ----------------------------------------------------------------------------
// EXITS  —  explicit trailing stop price + regime-break failsafe
//   On every bar while in position, take highest high since entry and trail
//   the stop `atr * trailAtr` below it.  The stop price only ratchets UP.
// ----------------------------------------------------------------------------
var float hhSinceEntry = na
var float trailStop    = na

if strategy.position_size > 0
    hhSinceEntry := na(hhSinceEntry) ? high : math.max(hhSinceEntry, high)
    newStop     = hhSinceEntry - atr * trailAtr
    trailStop   := na(trailStop) ? newStop : math.max(trailStop, newStop)
    strategy.exit("trail", from_entry = "L", stop = trailStop)

    if exitReg
        strategy.close("L", comment = "regime")
else
    // reset when flat
    hhSinceEntry := na
    trailStop    := na

// ----------------------------------------------------------------------------
// VISUALS
// ----------------------------------------------------------------------------
plot(donHi,  "Donchian(30) High", color = color.new(color.yellow, 40))
plot(regSma, "Regime SMA(150)",   color = color.new(color.orange, 0))
plot(strategy.position_size > 0 ? trailStop : na, "Trailing Stop",
     color = color.new(color.red, 0), style = plot.style_linebr)

bgcolor(regimeUp ? color.new(color.green, 93) : color.new(color.red, 93))

plotshape(longCond and strategy.position_size == 0,
     "Entry", style = shape.triangleup, location = location.belowbar,
     color = color.lime, size = size.tiny)

plotshape(exitReg and strategy.position_size > 0,
     "Regime exit", style = shape.xcross, location = location.abovebar,
     color = color.red, size = size.tiny)

// ----------------------------------------------------------------------------
// ALERTS  (webhook-ready JSON payloads)
// ----------------------------------------------------------------------------
alertcondition(longCond,
     title   = "V2B Long Entry",
     message = '{"action":"open_long","symbol":"{{ticker}}","tf":"{{interval}}","price":"{{close}}"}')

alertcondition(exitReg,
     title   = "V2B Regime Exit",
     message = '{"action":"close_long","symbol":"{{ticker}}","tf":"{{interval}}","price":"{{close}}"}')
