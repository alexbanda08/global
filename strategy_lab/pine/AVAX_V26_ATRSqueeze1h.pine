//@version=5
// ============================================================================
//  AVAX  —  V26 ATR Squeeze Breakout (1h)   —  LIVE CANDIDATE
// ============================================================================
//  Idea: ATR compression (current ATR < 75% of its 70-bar moving average) =
//        volatility coiling. A Donchian(20) breakout AFTER the squeeze, in
//        the direction of the regime (SMA 400) = directional release.
//
//  This was the only V26 price-action family to produce a clean, moderately
//  robust signal after the V26 Order_Block family was disqualified for
//  look-ahead bias (its huge CAGR numbers were backtest artifact).
//
//  Python backtest (2020-01 -> 2026-04, $10,000 start, 9 bps fee + 3 bps slip):
//    FULL  n=142   CAGR (net) +64.3%   Sharpe +1.32   DD -37.3%   PF 1.92
//      IS  (2020-2023)   n=78    Sharpe +1.37
//      OOS (2024-2026)   n=64    Sharpe +1.27   CAGR +65.3%   <- OOS holds
//
//  Status: LIVE CANDIDATE (with AVAX V23 + V25 already running).
//    Expected role: uncorrelated timing vs V23 BB-Break and V25 MTF Conf —
//    only fires in volatility-compression releases. 20-25% AVAX sleeve weight.
// ============================================================================

strategy("AVAX  V26 ATR Squeeze 1h",
     overlay             = true,
     initial_capital     = 10000,
     currency            = currency.USD,
     default_qty_type    = strategy.percent_of_equity,
     default_qty_value   = 100,
     commission_type     = strategy.commission.percent,
     commission_value    = 0.045,
     slippage            = 3,
     pyramiding          = 0,
     process_orders_on_close = false,
     close_entries_rule  = "ANY",
     margin_long         = 33,
     margin_short        = 33)

grpSig = "Signal (ATR squeeze + Donchian break)"
atrN    = input.int(14,   "ATR length", minval = 2, group = grpSig)
sqzRatio= input.float(0.75,"Squeeze ratio (ATR / avgATR <)", step = 0.05, group = grpSig)
atrSmaN = input.int(70,   "ATR SMA length (= 5 * ATR len)", minval = 10, group = grpSig)
donchN  = input.int(20,   "Donchian breakout length", minval = 5, group = grpSig)
regLen  = input.int(400,  "Regime SMA length", minval = 50, group = grpSig)

grpExit = "Exits (ATR)"
tpAtr   = input.float(10.0,"TP x ATR",   step = 0.5, group = grpExit)
slAtr   = input.float(2.0, "SL x ATR",   step = 0.1, group = grpExit)
trlAtr  = input.float(5.0, "Trail x ATR",step = 0.5, group = grpExit)
maxHold = input.int(72,    "Max hold (bars @ 1h)", minval = 4, group = grpExit)

grpRisk = "Sizing"
riskPct = input.float(5.0, "Risk per trade (% eq.)", step = 0.5, group = grpRisk)
levCap  = input.float(3.0, "Max leverage",            step = 0.5, group = grpRisk)

grpSide  = "Sides"
useLong  = input.bool(true, "Longs",  group = grpSide)
useShort = input.bool(true, "Shorts", group = grpSide)

// ============================================================================
//  Core
// ============================================================================
atrVal  = ta.atr(atrN)
atrAvg  = ta.sma(atrVal, atrSmaN)
inSqz   = (atrVal / atrAvg) < sqzRatio

// Donchian channel — shift by one bar to avoid intrabar self-reference
donchHi = ta.highest(high, donchN)[1]
donchLo = ta.lowest (low,  donchN)[1]

// Regime
regSma  = ta.sma(close, regLen)
regimeUp = close > regSma
regimeDn = close < regSma

// Squeeze-break signals (last bar was in squeeze, this bar breaks the channel)
longSig  = useLong  and (close > donchHi) and inSqz[1] and regimeUp
shortSig = useShort and (close < donchLo) and inSqz[1] and regimeDn

// ============================================================================
//  Sizing (risk-based with leverage cap)
// ============================================================================
stopDist    = slAtr * atrVal
riskDollars = strategy.equity * (riskPct / 100.0)
qtySized    = stopDist > 0 ? math.min(riskDollars / stopDist, strategy.equity * levCap / close) : 0

if longSig and strategy.position_size == 0
    strategy.entry("L", strategy.long, qty = qtySized,
                   alert_message = '{"action":"buy","ticker":"{{ticker}}","qty":"{{strategy.order.contracts}}","price":"{{close}}"}')

if shortSig and strategy.position_size == 0
    strategy.entry("S", strategy.short, qty = qtySized,
                   alert_message = '{"action":"sell","ticker":"{{ticker}}","qty":"{{strategy.order.contracts}}","price":"{{close}}"}')

// ============================================================================
//  Exits (TP / hard SL / trailing SL / max hold)
// ============================================================================
var float trailStop = na
var int   barsIn    = 0

if strategy.position_size > 0
    barsIn := barsIn + 1
    tp    = strategy.position_avg_price + tpAtr * atrVal
    hsl   = strategy.position_avg_price - slAtr * atrVal
    trail = high - trlAtr * atrVal
    trailStop := na(trailStop) ? hsl : math.max(trailStop, trail)
    trailStop := math.max(trailStop, hsl)
    strategy.exit("X-L", "L", limit = tp, stop = trailStop)
    if barsIn >= maxHold
        strategy.close("L", comment = "maxHold")
else if strategy.position_size < 0
    barsIn := barsIn + 1
    tp    = strategy.position_avg_price - tpAtr * atrVal
    hsl   = strategy.position_avg_price + slAtr * atrVal
    trail = low + trlAtr * atrVal
    trailStop := na(trailStop) ? hsl : math.min(trailStop, trail)
    trailStop := math.min(trailStop, hsl)
    strategy.exit("X-S", "S", limit = tp, stop = trailStop)
    if barsIn >= maxHold
        strategy.close("S", comment = "maxHold")
else
    trailStop := na
    barsIn := 0

// ============================================================================
//  Visuals
// ============================================================================
plot(donchHi, "Donch hi",  color = color.new(color.red,  40))
plot(donchLo, "Donch lo",  color = color.new(color.lime, 40))
plot(regSma,  "Regime SMA",color = color.new(color.aqua, 50))
bgcolor(inSqz ? color.new(color.purple, 90) : na)
plotshape(longSig,  title = "Long",  style = shape.triangleup,   location = location.belowbar, color = color.lime, size = size.tiny)
plotshape(shortSig, title = "Short", style = shape.triangledown, location = location.abovebar, color = color.red,  size = size.tiny)
