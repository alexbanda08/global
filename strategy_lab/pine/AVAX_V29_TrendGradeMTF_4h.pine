//@version=5
// ============================================================================
//  AVAX  —  V29 Trend-Grade MTF (4h)   —  LIVE CANDIDATE
// ============================================================================
//  Multi-timeframe trend-quality SCORE (0..4). Entries only fire when the
//  graded trend is strong AND an RSI pullback-then-recovery edge prints.
//
//  Grade = #{
//    4h EMA(50) slope up  over 20 bars,
//    1D EMA(50) > EMA(200),
//    1h close > 1h EMA(200),
//    1h ADX(14) > 15
//  }
//  Long:  grade >= 3 AND RSI(14) crosses UP through 45.
//  Short: grade >= 3 AND RSI(14) crosses DN through 55.
//
//  Python backtest (2020-01 -> 2026-04, $10k, 9 bps fee + 3 bps slip, 3x cap):
//    FULL  n=204  CAGR +11.2%  Sh +0.60  DD -37.4%  PF 1.26
//      IS  n=127  Sh +0.57  CAGR +10.4%
//      OOS n=76  Sh +0.73  CAGR +14.7%
//    Verdict: LIVE CANDIDATE — Steady +0.6 both sides; tight rsi ±5 edge
//
//  Causality: HTF series via request.security with barmerge.lookahead_off
//  (default) — no look-ahead leak.
// ============================================================================

strategy("AVAX  V29 Trend-Grade MTF 4h",
     overlay             = true,
     initial_capital     = 10000,
     currency            = currency.USD,
     default_qty_type    = strategy.percent_of_equity,
     default_qty_value   = 100,
     commission_type     = strategy.commission.percent,
     commission_value    = 0.045,
     slippage            = 3,
     pyramiding          = 0,
     process_orders_on_close = false,
     close_entries_rule  = "ANY",
     margin_long         = 33,
     margin_short        = 33)

grpSig   = "Grade components"
thr      = input.int(3, "Grade threshold",   minval = 1, maxval = 4, group = grpSig)
adxMin   = input.int(15, "Min ADX",       minval = 5, group = grpSig)
rsiLo    = input.int(45, "RSI long dip",   minval = 5, group = grpSig)
rsiHi    = input.int(55, "RSI short pop",  minval = 50, group = grpSig)

grpExit = "Exits (ATR)"
atrLen  = input.int(14, "ATR length",    minval = 2, group = grpExit)
tpAtr   = input.float(6.0, "TP x ATR", step = 0.5, group = grpExit)
slAtr   = input.float(1.5, "SL x ATR",   step = 0.1, group = grpExit)
trlAtr  = input.float(3.5, "Trail x ATR", step = 0.5, group = grpExit)
maxHold = input.int(20, "Max hold",     minval = 4,  group = grpExit)

grpRisk = "Sizing"
riskPct = input.float(3.0, "Risk/trade (% eq.)", step = 0.5, group = grpRisk)
levCap  = input.float(3.0, "Max leverage",          step = 0.5, group = grpRisk)

// --- Grade components ---
// (1) 4h EMA(50) slope up vs 20 bars ago
ema50   = ta.ema(close, 50)
slopeUp = ema50 > ema50[20]
slopeDn = ema50 < ema50[20]

// (2) Daily EMA50 > EMA200 (request.security default = no lookahead)
dEma50  = request.security(syminfo.tickerid, "D", ta.ema(close, 50))
dEma200 = request.security(syminfo.tickerid, "D", ta.ema(close, 200))
dBull = dEma50 > dEma200
dBear = dEma50 < dEma200

// (3) close vs local EMA(200)
e200 = ta.ema(close, 200)
locUp = close > e200
locDn = close < e200

// (4) ADX > adxMin
[_, _, adxV] = ta.dmi(14, 14)
adxOK = adxV > adxMin

// Grade
gUp = (slopeUp ? 1 : 0) + (dBull ? 1 : 0) + (locUp ? 1 : 0) + (adxOK ? 1 : 0)
gDn = (slopeDn ? 1 : 0) + (dBear ? 1 : 0) + (locDn ? 1 : 0) + (adxOK ? 1 : 0)

rsi = ta.rsi(close, 14)
dipUp = (rsi > rsiLo) and (rsi[1] <= rsiLo)
popDn = (rsi < rsiHi) and (rsi[1] >= rsiHi)

longSig  = (gUp >= thr) and dipUp
shortSig = (gDn >= thr) and popDn

// --- Sizing ---
atrVal = ta.atr(atrLen)
stopDist = slAtr * atrVal
riskDollars = strategy.equity * (riskPct / 100.0)
qtySized = stopDist > 0 ? math.min(riskDollars / stopDist, strategy.equity * levCap / close) : 0

if longSig and strategy.position_size == 0
    strategy.entry("L", strategy.long, qty = qtySized,
                   alert_message = '{"action":"buy","ticker":"{{ticker}}","qty":"{{strategy.order.contracts}}","price":"{{close}}"}')
if shortSig and strategy.position_size == 0
    strategy.entry("S", strategy.short, qty = qtySized,
                   alert_message = '{"action":"sell","ticker":"{{ticker}}","qty":"{{strategy.order.contracts}}","price":"{{close}}"}')

// --- Exits ---
var float trailStop = na
var int   barsIn    = 0

if strategy.position_size > 0
    barsIn := barsIn + 1
    tp    = strategy.position_avg_price + tpAtr * atrVal
    hsl   = strategy.position_avg_price - slAtr * atrVal
    trail = high - trlAtr * atrVal
    trailStop := na(trailStop) ? hsl : math.max(trailStop, trail)
    trailStop := math.max(trailStop, hsl)
    strategy.exit("X-L", "L", limit = tp, stop = trailStop)
    if barsIn >= maxHold
        strategy.close("L", comment = "maxHold")
else if strategy.position_size < 0
    barsIn := barsIn + 1
    tp    = strategy.position_avg_price - tpAtr * atrVal
    hsl   = strategy.position_avg_price + slAtr * atrVal
    trail = low + trlAtr * atrVal
    trailStop := na(trailStop) ? hsl : math.min(trailStop, trail)
    trailStop := math.min(trailStop, hsl)
    strategy.exit("X-S", "S", limit = tp, stop = trailStop)
    if barsIn >= maxHold
        strategy.close("S", comment = "maxHold")
else
    trailStop := na
    barsIn := 0

// --- Grade plot ---
plot(ema50, "4h EMA50",  color = color.new(color.aqua, 40))
plot(e200,  "1h EMA200", color = color.new(color.orange, 40))
plotshape(longSig,  title = "Long",  style = shape.triangleup,   location = location.belowbar, color = color.lime, size = size.small)
plotshape(shortSig, title = "Short", style = shape.triangledown, location = location.abovebar, color = color.red,  size = size.small)
